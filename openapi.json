{
  "openapi": "3.0.0",
  "info": {
    "title": "Créer ma Micro-Entreprise API",
    "description": "API backend pour le GPT de création de micro-entreprise en France.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://chatgpt-micro-entreprise-production.up.railway.app"
    }
  ],
  "paths": {
    "/api/dossier": {
      "post": {
        "operationId": "saveDossier",
        "summary": "Sauvegarder ou mettre à jour un dossier",
        "description": "Crée ou met à jour un dossier avec les informations collectées.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["session_id"],
                "properties": {
                  "session_id": {
                    "type": "string",
                    "description": "Identifiant unique de la conversation ChatGPT"
                  },
                  "first_name": {
                    "type": "string",
                    "description": "Prénom du créateur"
                  },
                  "last_name": {
                    "type": "string",
                    "description": "Nom de famille"
                  },
                  "date_of_birth": {
                    "type": "string",
                    "description": "Date de naissance YYYY-MM-DD"
                  },
                  "place_of_birth": {
                    "type": "string",
                    "description": "Lieu de naissance"
                  },
                  "nationality": {
                    "type": "string",
                    "description": "Nationalité"
                  },
                  "activity_type": {
                    "type": "string",
                    "enum": ["commercial", "artisanal", "liberal"],
                    "description": "Type d'activité"
                  },
                  "activity_desc": {
                    "type": "string",
                    "description": "Description de l'activité"
                  },
                  "naf_code": {
                    "type": "string",
                    "description": "Code APE/NAF"
                  },
                  "enterprise_addr": {
                    "type": "string",
                    "description": "Adresse de domiciliation"
                  },
                  "acre_option": {
                    "type": "boolean",
                    "description": "Option ACRE"
                  },
                  "versement_lib": {
                    "type": "boolean",
                    "description": "Option versement libératoire"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dossier sauvegardé",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "dossier_id": { "type": "string" },
                    "session_id": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/dossier/{sessionId}": {
      "get": {
        "operationId": "getDossier",
        "summary": "Récupérer un dossier",
        "description": "Récupère toutes les informations d'un dossier existant.",
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Identifiant de session"
          }
        ],
        "responses": {
          "200": {
            "description": "Détails du dossier",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "dossier": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/dossier/{sessionId}/summary": {
      "get": {
        "operationId": "getDossierSummary",
        "summary": "Récapitulatif du dossier",
        "description": "Retourne un récapitulatif du dossier avant paiement.",
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Identifiant de session"
          }
        ],
        "responses": {
          "200": {
            "description": "Récapitulatif",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "summary": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/naf/search": {
      "get": {
        "operationId": "searchNafCode",
        "summary": "Rechercher un code APE/NAF",
        "description": "Recherche les codes NAF pour une activité donnée.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Mots-clés de recherche"
          }
        ],
        "responses": {
          "200": {
            "description": "Résultats",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "query": { "type": "string" },
                    "count": { "type": "integer" },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "code": { "type": "string" },
                          "label": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/document/validate-url": {
      "post": {
        "operationId": "validateDocument",
        "summary": "Valider un document",
        "description": "Valide un document uploadé via son URL.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["session_id", "document_type", "file_url"],
                "properties": {
                  "session_id": {
                    "type": "string",
                    "description": "Identifiant de session"
                  },
                  "document_type": {
                    "type": "string",
                    "enum": ["id_document", "domicile_proof", "non_condamnation"],
                    "description": "Type de document"
                  },
                  "file_url": {
                    "type": "string",
                    "description": "URL du fichier"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Résultat de validation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "document_id": { "type": "string" },
                    "is_valid": { "type": "boolean" },
                    "issues": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/payment/create": {
      "post": {
        "operationId": "createPayment",
        "summary": "Créer un lien de paiement",
        "description": "Génère un lien de paiement Stripe pour le dossier.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["session_id"],
                "properties": {
                  "session_id": {
                    "type": "string",
                    "description": "Identifiant de session"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lien de paiement",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "payment_url": { "type": "string" },
                    "amount": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/payment/status/{sessionId}": {
      "get": {
        "operationId": "checkPaymentStatus",
        "summary": "Vérifier le statut du paiement",
        "description": "Vérifie si le paiement Stripe a été complété.",
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Identifiant de session"
          }
        ],
        "responses": {
          "200": {
            "description": "Statut du paiement",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "payment_status": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/inpi/submit": {
      "post": {
        "operationId": "submitToInpi",
        "summary": "Soumettre le dossier à l'INPI",
        "description": "Soumet le dossier au Guichet Unique INPI après paiement.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["session_id"],
                "properties": {
                  "session_id": {
                    "type": "string",
                    "description": "Identifiant de session"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Résultat de soumission",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "formalite_id": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/inpi/status/{sessionId}": {
      "get": {
        "operationId": "checkInpiStatus",
        "summary": "Vérifier le statut INPI",
        "description": "Vérifie le statut de la soumission INPI et récupère le SIRET.",
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Identifiant de session"
          }
        ],
        "responses": {
          "200": {
            "description": "Statut INPI",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "inpi_status": { "type": "string" },
                    "siret": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
